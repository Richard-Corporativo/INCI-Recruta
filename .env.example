# Supabase Configuration (Next.js)
# Get these values from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Example format:
# VITE_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --> Para desenvolvimento local: Crie um arquivo .env com os valores reais
# --> Para produção (Vercel): Adicione estas variáveis em Project Settings > Environment Variables

# Notificações
RH_NOTIFICATIONS_EMAIL=rh@suaempresa.com.br
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
